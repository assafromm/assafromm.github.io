@article{dreyfuss2026deferred,
  author         = {Bnaya Dreyfuss and Ofer Glicksohn and Ori Heffetz and Assaf Romm},
  title          = {Deferred Acceptance with News Utility},
  journal        = {Management Science},
  year           = {2026},
  volume         = {72},
  number         = {3},
  pages          = {2090--2110},
  doi            = {10.1287/mnsc.2024.05446},
  abstract       = {We investigate whether incorporating Expectations-Based Reference-Dependent (EBRD) preferences can account for observed deviations from straightforward play in the Deferred Acceptance (DA) mechanism. In two experiments with approximately 500 participants randomly assigned to one of four DA variants (static/dynamic x student-proposing/student-receiving), we find that dynamic student-receiving DA leads to significantly fewer deviations from straightforward play. Within variants, deviations increase with market competitiveness; within problems, the specific deviations that EBRD predicts are those commonly observed.},
  categories     = {Behavioral Market Design, Matching Theory},
  publishedurl   = {https://pubsonline.informs.org/doi/10.1287/mnsc.2024.05446},
  workingpaperurl = {https://www.nber.org/papers/w30635}
}

@article{romm2024stability,
  author         = {Assaf Romm and Alvin E. Roth and Ran I. Shorrer},
  title          = {Stability vs. No Justified Envy},
  journal        = {Games and Economic Behavior},
  year           = {2024},
  volume         = {148},
  pages          = {357--366},
  doi            = {10.1016/j.geb.2024.10.002},
  abstract       = {Stability and no justified envy are used almost synonymously in the matching theory literature. However, they are conceptually different and have logically separate properties. We generalize the definition of justified envy to environments with arbitrary school preferences, feasibility constraints, and contracts, and show that stable allocations may admit justified envy. When choice functions are substitutable, the outcome of the deferred acceptance algorithm is both stable and admits no justified envy.},
  categories     = {Matching Theory},
  publishedurl   = {https://doi.org/10.1016/j.geb.2024.10.002},
  workingpaperurl = {https://papers.ssrn.com/sol3/papers.cfm?abstract_id=3550122}
}

@article{biro2020large,
  author         = {P{\'e}ter Bir{\'o} and Avinatan Hassidim and Assaf Romm and Ran I. Shorrer and S{\'a}ndor S{\'o}v{\'a}g{\'o}},
  title          = {The Large Core of College Admission Markets: Theory and Evidence},
  journal        = {Review of Economics and Statistics},
  year           = {2025},
  doi            = {10.1162/REST.a.1628},
  abstract       = {We study the core of college admission markets. Theoretically, we demonstrate that the core tends to be large in settings with many students and colleges, providing conditions under which a large fraction of students can be matched to different colleges without violating stability. Empirically, using data from the Hungarian college admission market, we find evidence broadly consistent with theoretical predictions: the stable matching is far from unique, and alternative stable matchings yield substantially different outcomes for many students.},
  categories     = {Matching Theory},
  publishedurl   = {https://direct.mit.edu/rest/article-abstract/doi/10.1162/REST.a.1628/133694/The-Large-Core-of-College-Admission-Markets-Theory},
  workingpaperurl = {https://arxiv.org/abs/2010.08631}
}

@inproceedings{gonczarowski2019matching,
  author         = {Yannai A. Gonczarowski and Lior Kovalio and Noam Nisan and Assaf Romm},
  title          = {Matching for the Israeli ``{Mechinot}'' Gap-Year Programs: Handling Rich Diversity Requirements},
  booktitle      = {Proceedings of the 2019 ACM Conference on Economics and Computation (EC'19)},
  year           = {2019},
  doi            = {10.1145/3328526.3329620},
  abstract       = {We describe the design and implementation of a centralized matching mechanism for the Israeli gap-year (mechinot) preparatory programs. The main challenge is handling a rich set of diversity requirements: each program has constraints on the types and numbers of students it admits, and these constraints interact in complex ways. We present a mechanism based on deferred acceptance with adaptations to handle the diversity requirements, and discuss the practical challenges encountered in deployment.},
  categories     = {Practical Market Design, Matching Theory},
  workingpaperurl = {https://arxiv.org/abs/1905.00364}
}

@article{hassidim2021limits,
  author         = {Avinatan Hassidim and Assaf Romm and Ran I. Shorrer},
  title          = {The Limits of Incentives in Economic Matching Procedures},
  journal        = {Management Science},
  year           = {2021},
  volume         = {67},
  number         = {2},
  pages          = {951--963},
  doi            = {10.1287/mnsc.2020.3591},
  abstract       = {We study the limits of incentives in economic matching procedures. We show that the individual gain from strategic manipulation in large two-sided matching markets is asymptotically negligible under mild regularity conditions. This result helps explain why strategy-proof mechanisms can be successfully deployed in large real-life markets, even in settings where participants are sophisticated and may contemplate manipulation.},
  categories     = {Behavioral Market Design},
  publishedurl   = {https://pubsonline.informs.org/doi/10.1287/mnsc.2020.3591},
  workingpaperurl = {https://papers.ssrn.com/sol3/papers.cfm?abstract_id=2784659},
  ecnote         = {Extended abstract @ EC'16, under the title ``'Strategic' Behavior in a Strategy-Proof Environment''}
}

@article{ashlagi2019assigning,
  author         = {Itai Ashlagi and Afshin Nikzad and Assaf Romm},
  title          = {Assigning More Students to Their Top Choices: A Comparison of Tie-Breaking Rules},
  journal        = {Games and Economic Behavior},
  year           = {2019},
  volume         = {115},
  pages          = {167--187},
  doi            = {10.1016/j.geb.2019.02.015},
  abstract       = {School districts that implement stable matchings face various decisions that affect students' assignments to schools. We study the properties of the rank distribution of students with random preferences when schools use different tie-breaking rules to rank equivalent students. Under a single tie-breaking rule (STB), where all schools use the same ranking, a constant fraction of students are assigned to one of their top choices. In contrast, under a multiple tie-breaking rule (MTB), where each school independently ranks students, a vanishing fraction of students are matched with one of their top choices. However, if students are allowed to submit only relatively short preference lists under MTB, a constant fraction of students will be matched with one of their top choices, while only a small fraction will remain unmatched.},
  categories     = {Matching Theory},
  publishedurl   = {https://doi.org/10.1016/j.geb.2019.02.015},
  workingpaperurl = {https://papers.ssrn.com/sol3/papers.cfm?abstract_id=2585367},
  ecnote         = {Extended abstract @ EC'15}
}

@article{hassidim2019contracts,
  author         = {Avinatan Hassidim and Assaf Romm and Ran I. Shorrer},
  title          = {Contracts Are Not Salaries in the Hidden-Substitutes Domain},
  journal        = {Economics Letters},
  year           = {2019},
  volume         = {181},
  pages          = {40--42},
  doi            = {10.1016/j.econlet.2019.04.025},
  abstract       = {We show that in the hidden-substitutes domain, the standard translation of a many-to-one matching market with salaries into a matching market with contracts yields incorrect conclusions: contracts and salaries are not equivalent in this domain, contrary to what has been claimed in the literature.},
  categories     = {Matching Theory},
  publishedurl   = {https://doi.org/10.1016/j.econlet.2019.04.025}
}

@article{alon2018redesigning,
  author         = {Noga Alon and Slava Bronfman and Avinatan Hassidim and Assaf Romm},
  title          = {Redesigning the Israeli Medical Internship Match},
  journal        = {ACM Transactions on Economics and Computation},
  year           = {2018},
  volume         = {6},
  number         = {3--4},
  pages          = {14:1--14:28},
  doi            = {10.1145/3274646},
  abstract       = {The final step in getting an Israeli MD is performing a year-long internship in one of the hospitals in Israel. We describe the redesign of the Israeli Medical Internship Match from a lottery to a Deferred Acceptance mechanism. A key challenge is handling couples (the two-body problem). We show that decomposing stochastic assignment matrices into deterministic allocations is NP-hard in the presence of couples, and provide a polynomial-time algorithm with the optimal worst-case guarantee.},
  categories     = {Practical Market Design, Matching Theory},
  publishedurl   = {https://dl.acm.org/doi/10.1145/3274646},
  workingpaperurl = {https://papers.ssrn.com/sol3/papers.cfm?abstract_id=2603546},
  ecnote         = {Extended abstract @ EC'15}
}

@article{hassidim2017redesigning,
  author         = {Avinatan Hassidim and Assaf Romm and Ran I. Shorrer},
  title          = {Redesigning the Israeli Psychology Master's Match},
  journal        = {American Economic Review (Papers and Proceedings)},
  year           = {2017},
  volume         = {107},
  number         = {5},
  pages          = {205--209},
  doi            = {10.1257/aer.p20171048},
  abstract       = {We describe the redesign of the Israeli Psychology Master's admissions process. The previous mechanism was a serial dictatorship, which we replaced with a Deferred Acceptance mechanism after documenting that a substantial fraction of students submitted non-truthful reports under the old mechanism. We discuss the implementation process and the impact of the redesign.},
  categories     = {Practical Market Design, Matching Theory},
  publishedurl   = {https://www.aeaweb.org/articles?id=10.1257/aer.p20171048},
  ecnote         = {Extended abstract @ EC'17}
}

@article{hassidim2017mechanism,
  author         = {Avinatan Hassidim and D{\'e}borah Marciano and Assaf Romm and Ran I. Shorrer},
  title          = {The Mechanism Is Truthful, Why Aren't You?},
  journal        = {American Economic Review (Papers and Proceedings)},
  year           = {2017},
  volume         = {107},
  number         = {5},
  pages          = {220--224},
  doi            = {10.1257/aer.p20171027},
  abstract       = {We document widespread non-truthful behavior in a real market that uses a strategy-proof mechanism. Studying participants' submitted preference lists in the Israeli Psychology Master's Match, we find that many students submit non-truthful reports despite truth-telling being a dominant strategy. We provide evidence that this behavior reflects misunderstanding of the mechanism rather than strategic sophistication.},
  categories     = {Behavioral Market Design},
  publishedurl   = {https://www.aeaweb.org/articles?id=10.1257/aer.p20171027}
}

@article{marciano2016alternative,
  author         = {D{\'e}borah Marciano-Romm and Assaf Romm and Sacha Bourgeois-Gironde and Leon Y. Deouell},
  title          = {The Alternative Omen Effect: Illusory Negative Correlation Between the Outcomes of Choice Options},
  journal        = {Cognition},
  year           = {2016},
  volume         = {146},
  pages          = {324--338},
  doi            = {10.1016/j.cognition.2015.10.003},
  abstract       = {We identify a cognitive bias we term the Alternative Omen Effect: people tend to believe that if one alternative turns out to be good, other alternatives would have turned out poorly, even when outcomes are statistically independent. We document this effect using behavioral experiments and EEG measures, and discuss its implications for decision-making under uncertainty.},
  categories     = {Other},
  publishedurl   = {https://doi.org/10.1016/j.cognition.2015.10.003}
}

@article{frick2015rational,
  author         = {Mira Frick and Assaf Romm},
  title          = {Rational Behavior Under Correlated Uncertainty},
  journal        = {Journal of Economic Theory},
  year           = {2015},
  volume         = {160},
  pages          = {56--71},
  doi            = {10.1016/j.jet.2015.08.009},
  abstract       = {We provide a framework for understanding when apparently irrational behavior---including preference reversals and violations of expected utility---can be rationalized as optimal behavior under correlated uncertainty. When a decision maker faces uncertainty about both the outcomes of actions and the realization of exogenous states, correlations between these sources of uncertainty can generate behavior that violates standard rationality axioms. We characterize the class of preferences that can be rationalized in this way.},
  categories     = {Game Theory},
  publishedurl   = {https://doi.org/10.1016/j.jet.2015.08.009}
}

@article{romm2014implications,
  author         = {Assaf Romm},
  title          = {Implications of Capacity Reduction and Entry in Many-to-One Stable Matching},
  journal        = {Social Choice and Welfare},
  year           = {2014},
  volume         = {43},
  number         = {4},
  pages          = {851--875},
  doi            = {10.1007/s00355-014-0813-z},
  abstract       = {We study how changes in market composition---capacity reductions and entry of new agents---affect stable matchings in many-to-one matching markets. A capacity reduction by one firm can benefit other firms (a strategic capacity reduction), and entry of a new firm can sometimes harm existing participants. These results have implications for antitrust analysis and market design in matching markets.},
  categories     = {Matching Theory},
  publishedurl   = {https://link.springer.com/article/10.1007/s00355-014-0813-z}
}
